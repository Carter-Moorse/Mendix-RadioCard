<?xml version="1.0" encoding="utf-8"?>
<widget id="auraq.radiocard.RadioCard" pluginWidget="true" needsEntityContext="true" offlineCapable="true"
        supportedPlatform="Web"
        xmlns="http://www.mendix.com/widget/1.0/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.mendix.com/widget/1.0/ ../node_modules/mendix/custom_widget.xsd">
    <name>Radio Card</name>
    <description>Customisable radio card display</description>
    <icon/>
    <properties>
        <propertyGroup caption="General">
            <propertyGroup caption="Data source">
                <property key="type" type="enumeration" defaultValue="attribute">
                    <caption>Type</caption>
                    <description></description>
                    <enumerationValues>
                        <enumerationValue key="attribute">Attribute</enumerationValue>
                        <enumerationValue key="association">Association</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="customContent" type="boolean" defaultValue="false">
                    <caption>Custom content?</caption>
                    <description></description>
                </property>
                <!-- Association -->
                <property key="reference" type="association" selectableObjects="selectableObjects" onChange="onChangeReference" setLabel="true">
                    <caption>Reference</caption>
                    <description>Reference</description>
                    <associationTypes>
                        <associationType name="Reference"/>
                    </associationTypes>
                </property>
                <property key="selectableObjects" type="datasource" isList="true">
                    <caption>Selectable objects</caption>
                    <description/>
                </property>
                <!-- No custom content -->
                <property key="displayValueReference" type="expression" dataSource="selectableObjects">
                    <caption>Display value</caption>
                    <description></description>
                    <returnType type="String" />
                </property>
                <!-- Custom content -->
                <property key="contentReference" type="widgets" required="true" dataSource="selectableObjects">
                    <caption>Content</caption>
                    <description></description>
                </property>
                <!-- Attribute -->
                <property key="attribute" type="attribute" onChange="onChangeAttribute" setLabel="true">
                    <caption>Attribute</caption>
                    <description></description>
                    <attributeTypes>
                        <attributeType name="Enum"/>
                        <attributeType name="Boolean"/>
                    </attributeTypes>
                </property>
                <!-- Custom content -->
                <property key="displayItems" type="object" isList="true">
                    <caption>Display items</caption>
                    <description/>
                    <properties>
                        <propertyGroup caption="General">
                            <propertyGroup caption="General">
                                <property key="content" type="widgets" required="false">
                                    <caption>Content</caption>
                                    <description></description>
                                </property>
                                <property key="value" type="expression">
                                    <caption>Value</caption>
                                    <description></description>
                                    <returnType assignableTo="../attribute" />
                                </property>
                                <property key="dynamicClasses" type="expression" required="false">
                                    <caption>Dynamic classes</caption>
                                    <description></description>
                                    <returnType type="String" />
                                </property>
                            </propertyGroup>
                            <propertyGroup caption="Responsiveness">
                                <property key="desktopWidth" type="enumeration" defaultValue="autofill">
                                    <caption>Desktop width</caption>
                                    <description></description>
                                    <enumerationValues>
                                        <enumerationValue key="autofill">Auto-fill</enumerationValue>
                                        <enumerationValue key="autofitContent">Auto-fit content</enumerationValue>
                                        <enumerationValue key="manual">Manual</enumerationValue>
                                    </enumerationValues>
                                </property>
                                <property key="desktopSize" type="integer" required="true" defaultValue="6">
                                    <caption>Desktop size</caption>
                                    <description></description>
                                </property>
                                <property key="tabletWidth" type="enumeration" defaultValue="autofill">
                                    <caption>Tablet width</caption>
                                    <description></description>
                                    <enumerationValues>
                                        <enumerationValue key="autofill">Auto-fill</enumerationValue>
                                        <enumerationValue key="autofitContent">Auto-fit content</enumerationValue>
                                        <enumerationValue key="manual">Manual</enumerationValue>
                                    </enumerationValues>
                                </property>
                                <property key="tabletSize" type="integer" required="true" defaultValue="6">
                                    <caption>Tablet size</caption>
                                    <description></description>
                                </property>
                                <property key="phoneWidth" type="enumeration" defaultValue="autofill">
                                    <caption>Phone width</caption>
                                    <description></description>
                                    <enumerationValues>
                                        <enumerationValue key="autofill">Auto-fill</enumerationValue>
                                        <enumerationValue key="autofitContent">Auto-fit content</enumerationValue>
                                        <enumerationValue key="manual">Manual</enumerationValue>
                                    </enumerationValues>
                                </property>
                                <property key="phoneSize" type="integer" required="true" defaultValue="6">
                                    <caption>Phone size</caption>
                                    <description></description>
                                </property>
                            </propertyGroup>
                        </propertyGroup>
                    </properties>
                </property>
            </propertyGroup>
            <propertyGroup caption="Label">
                <systemProperty key="Label"/>
            </propertyGroup>
            <propertyGroup caption="Editability">
                <systemProperty key="Editability"/>
            </propertyGroup>
            <propertyGroup caption="Visibility">
                <systemProperty key="Visibility"/>
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Display">
            <propertyGroup caption="Container">
                <property key="fullSizeContainer" type="boolean" defaultValue="true">
                    <caption>Full size?</caption>
                    <description></description>
                </property>
                <property key="containerClass" type="string" required="false">
                    <caption>Class</caption>
                    <description></description>
                </property>
            </propertyGroup>
            <propertyGroup caption="Card">
                <property key="hideRadioInput" type="boolean" defaultValue="false">
                    <caption>Hide radio input?</caption>
                    <description></description>
                </property>
                <property key="radioPosition" type="enumeration" defaultValue="left">
                    <caption>Radio position</caption>
                    <description>Controls position of the radio input relative to the item content</description>
                    <enumerationValues>
                        <enumerationValue key="left">Left</enumerationValue>
                        <enumerationValue key="right">Right</enumerationValue>
                        <enumerationValue key="above">Above</enumerationValue>
                        <enumerationValue key="below">Below</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="cardAlignment" type="enumeration" defaultValue="center">
                    <caption>Card alignment</caption>
                    <description>Controls alignment of content within the radio card item</description>
                    <enumerationValues>
                        <enumerationValue key="start">Start</enumerationValue>
                        <enumerationValue key="center">Center</enumerationValue>
                        <enumerationValue key="end">End</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="cardSize" type="enumeration" defaultValue="normal">
                    <caption>Card size</caption>
                    <description>Controls the visual size and spacing of each radio card item (small, normal, large) for better layout and readability.</description>
                    <enumerationValues>
                        <enumerationValue key="small">Small</enumerationValue>
                        <enumerationValue key="normal">Normal</enumerationValue>
                        <enumerationValue key="large">Large</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="highlightSelected" type="boolean" defaultValue="false">
                    <caption>Highlight selected?</caption>
                    <description></description>
                </property>
                <property key="selectedClass" type="string" required="false">
                    <caption>Selected class</caption>
                    <description></description>
                </property>
                <property key="dynamicClasses" type="expression" required="false">
                    <caption>Dynamic classes</caption>
                    <description></description>
                    <returnType type="String" />
                </property>
                <property key="dynamicClassesReference" type="expression" required="false" dataSource="selectableObjects">
                    <caption>Dynamic classes</caption>
                    <description></description>
                    <returnType type="String" />
                </property>
            </propertyGroup>
            <propertyGroup caption="Responsiveness">
                <!-- Responsive display -->
                <property key="desktopWidth" type="enumeration" defaultValue="autofill">
                    <caption>Desktop width</caption>
                    <description></description>
                    <enumerationValues>
                        <enumerationValue key="autofill">Auto-fill</enumerationValue>
                        <enumerationValue key="autofitContent">Auto-fit content</enumerationValue>
                        <enumerationValue key="manual">Manual</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="desktopSize" type="integer" required="true" defaultValue="6">
                    <caption>Desktop size</caption>
                    <description></description>
                </property>
                <property key="tabletWidth" type="enumeration" defaultValue="autofill">
                    <caption>Tablet width</caption>
                    <description></description>
                    <enumerationValues>
                        <enumerationValue key="autofill">Auto-fill</enumerationValue>
                        <enumerationValue key="autofitContent">Auto-fit content</enumerationValue>
                        <enumerationValue key="manual">Manual</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="tabletSize" type="integer" required="true" defaultValue="6">
                    <caption>Tablet size</caption>
                    <description></description>
                </property>
                <property key="phoneWidth" type="enumeration" defaultValue="autofill">
                    <caption>Phone width</caption>
                    <description></description>
                    <enumerationValues>
                        <enumerationValue key="autofill">Auto-fill</enumerationValue>
                        <enumerationValue key="autofitContent">Auto-fit content</enumerationValue>
                        <enumerationValue key="manual">Manual</enumerationValue>
                    </enumerationValues>
                </property>
                <property key="phoneSize" type="integer" required="true" defaultValue="6">
                    <caption>Phone size</caption>
                    <description></description>
                </property>
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Common">
            <propertyGroup caption="Common">
                <systemProperty key="Name"/>
                <systemProperty key="TabIndex"/>
            </propertyGroup>
        </propertyGroup>
        <propertyGroup caption="Events">
            <propertyGroup caption="Events">
                <property key="onChangeAttribute" type="action">
                    <caption>On change</caption>
                    <description/>
                </property>
                <property key="onChangeReference" type="action">
                    <caption>On change</caption>
                    <description/>
                </property>
            </propertyGroup>
        </propertyGroup>
    </properties>
</widget>